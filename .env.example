# =============================================================================
# Copy to .env and fill in. DB_* you already have — keep those.
# =============================================================================

# --- MySQL (you already set these) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=t_bot

# --- Telegram (REQUIRED — get from @BotFather) ---
TELEGRAM_BOT_TOKEN=
# Public HTTPS URL of this app (ngrok / Railway / Render) — needed for webhook
PUBLIC_BASE_URL=

# --- Gemini free API (REQUIRED — https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Recent messages the bot replays for short-term memory (0 = off)
HISTORY_LIMIT=20

# --- Voice STT ---
# gemini = use Gemini audio (no extra key)
# openai = use Whisper (needs OPENAI_API_KEY)
# none   = disable voice for now
STT_PROVIDER=gemini
OPENAI_API_KEY=

# --- App ---
APP_ENV=development
GENERATED_DIR=generated
LOG_DIR=logs
# polling = local testing (no PUBLIC_BASE_URL needed)
# webhook = needs PUBLIC_BASE_URL
TELEGRAM_MODE=polling

# Scheduled reports (owner sets time via chat, e.g. "send daily report at 9pm")
SCHEDULER_ENABLED=true
REPORT_TIMEZONE=Asia/Kolkata
